{
  "name": "lifeguard-platform",
  "version": "1.0.0",
  "private": true,
  "description": "LifeGuard — personal-safety + lone-worker + family emergency platform. Marketing site, family app, operator console, reseller dashboard.",
  "workspaces": [
    "marketing",
    "family",
    "console",
    "reseller"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "db:up": "docker compose up postgres -d",
    "db:seed": "psql $POSTGRES_URL -f sql/schema.sql",
    "seed:data": "python seed/generate.py"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
